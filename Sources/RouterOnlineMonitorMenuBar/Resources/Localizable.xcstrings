    "help.capacityLimits" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erforderlich. Maximale Downstream- und Upstream-Leitungsgeschwindigkeiten für Rechtecke, Prozentwerte und Warnungen nahe der Kapazitätsgrenze festlegen. Wenn die automatische Erkennung nicht verfügbar ist, beide Werte manuell eingeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Required. Set the maximum downstream and upstream line speeds used for rectangles, percentages, and near-capacity warnings. If automatic detection is unavailable, enter both values manually."
          }
        }
      }
    },
    "help.menuBarDisplay.minimalist" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt nur das App-Symbol. Der jeweilige Pfeil wird rot, wenn Download oder Upload das erforderliche Leitungslimit erreicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shows only the app icon. The corresponding arrow turns red when download or upload reaches the required line speed limit."
          }
        }
      }
    },
    "help.menuBarDisplay.percentage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt den aktuellen Verkehr als Prozentwerte der erforderlichen Leitungslimits."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shows current traffic as percentages of the required line speed limits."
          }
        }
      }
    },
    "help.menuBarDisplay.rate" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt den aktuellen Verkehr als Werte. Die Dezimalgenauigkeit gilt nur für diese Werteanzeige."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shows current traffic as values. Decimal precision applies only to this value display."
          }
        }
      }
    },
    "help.menuBarDisplay.rectangles" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt kompakte Nutzungsrechtecke anhand der erforderlichen Leitungslimits."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shows compact usage rectangles based on the required line speed limits."
          }
        }
      }
    },
    "help.menuBarDisplay.stableText" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt Traffic-Werte mit fester Breite in einer Monospace-Schrift. Kleine Werte erscheinen als 0 Mbit statt als Kleiner-als-Text."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shows fixed-width monospaced traffic values. Small values display as 0 Mbit instead of less-than text."
          }
        }
      }
    },
    "help.pollingInterval" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mindestens 1 Sekunde. Werte unter 5 Sekunden können unruhiger wirken, weil manche Router Verkehrszähler in Bursts aktualisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minimum 1 second. Values below 5 seconds can look noisier because some routers update traffic counters in bursts."
          }
        }
      }
    },
    "help.showOneDecimalPlace" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
